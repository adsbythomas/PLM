---
import '../styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import type { Practice } from '@lib/site';

export interface Props {
  title: string;
  description: string;
  practice: Practice;
  canonical?: string;
}
const { title, description, practice, canonical } = Astro.props;
const themeClass = practice === 'legal' ? 'theme-legal' : 'theme-accounting';
const themeColor = practice === 'legal' ? '#142a46' : '#63300f';
---
<!doctype html>
<html lang="es" class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    {canonical && <link rel="canonical" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><rect width='64' height='64' rx='10' fill='${encodeURIComponent(themeColor)}'/><text x='50%25' y='56%25' font-family='Georgia,serif' font-size='26' font-weight='700' text-anchor='middle' dominant-baseline='middle' fill='%23f4efe5'>PLB</text></svg>`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': practice === 'legal' ? 'LegalService' : 'AccountingService',
      name: 'Pantarotto Lértora Bardagí & Asocs.',
      description,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Av. Corrientes 1464, Piso 16 Of. 1605',
        postalCode: 'C1042',
        addressLocality: 'Buenos Aires',
        addressCountry: 'AR',
      },
      foundingDate: '2004',
    })} />
  </head>
  <body class="grain">
    <!-- Preloader -->
    <div class="preloader" id="preloader" aria-hidden="true">
      <svg viewBox="0 0 100 100">
        <path class="pre-stroke" d="M 20 80 L 20 20 L 35 20 Q 50 20 50 35 Q 50 50 35 50 L 20 50 M 50 80 L 50 20 L 70 20 Q 85 20 85 35 Q 85 45 72 48 L 85 80"/>
      </svg>
      <div class="pre-label">Pantarotto · Lértora · Bardagí</div>
    </div>

    <!-- Skip -->
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:bg-white focus:px-4 focus:py-2 focus:z-50 focus:text-ink-900">Saltar al contenido</a>

    <Nav practice={practice} />

    <main id="main"><slot /></main>

    <Footer practice={practice} />

    <script is:inline>
      // ═══════════════════════════════════════════════
      // Preloader — desaparece cuando el DOM carga
      // ═══════════════════════════════════════════════
      window.addEventListener('load', () => {
        setTimeout(() => document.getElementById('preloader')?.classList.add('done'), 900);
      });

      // ═══════════════════════════════════════════════
      // Scroll progress bar
      // ═══════════════════════════════════════════════
      const progressBar = document.getElementById('scrollProgress');
      const nav = document.querySelector('[data-nav]');
      const onScroll = () => {
        const h = document.documentElement;
        const scrolled = (h.scrollTop) / (h.scrollHeight - h.clientHeight);
        if (progressBar) progressBar.style.setProperty('--progress', String(scrolled));
        if (nav) nav.classList.toggle('solid', h.scrollTop > 40);

        // Parallax
        document.querySelectorAll('[data-parallax]').forEach((el) => {
          const speed = parseFloat(el.getAttribute('data-parallax-speed') || '0.2');
          const rect = el.getBoundingClientRect();
          const off = (rect.top + rect.height / 2 - window.innerHeight / 2) * speed * -1;
          el.style.setProperty('--p-offset', off + 'px');
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // ═══════════════════════════════════════════════
      // Reveal on scroll — para .reveal y .stack-line y .skyline y .blueprint y .split-word
      // ═══════════════════════════════════════════════
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in');
            e.target.classList.add('in-view');

            // stagger los stack-lines dentro del reveal
            const lines = e.target.querySelectorAll?.('[data-stack-line]');
            lines?.forEach?.((l, i) => {
              setTimeout(() => l.classList.add('in'), i * 90);
            });

            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

      document.querySelectorAll('.reveal, .skyline, .blueprint, [data-stack-line], [data-team-row]').forEach((el) => io.observe(el));

      // ═══════════════════════════════════════════════
      // Counters — count-up al entrar en viewport
      // ═══════════════════════════════════════════════
      const counters = document.querySelectorAll('[data-counter]');
      const counterIO = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const target = parseFloat(e.target.getAttribute('data-target') || '0');
          const valEl = e.target.querySelector('[data-counter-val]');
          if (!valEl) return;
          const dur = 1600;
          const start = performance.now();
          const step = (t) => {
            const p = Math.min(1, (t - start) / dur);
            const ease = 1 - Math.pow(1 - p, 3);
            valEl.textContent = Math.round(target * ease).toString();
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
          counterIO.unobserve(e.target);
        });
      }, { threshold: 0.4 });
      counters.forEach((c) => counterIO.observe(c));

      // Nota: cursor personalizado y magnetic buttons removidos
      // para un look más sobrio y corporativo.

      // ═══════════════════════════════════════════════
      // Menú mobile
      // ═══════════════════════════════════════════════
      const openBtn = document.getElementById('mob-open');
      const closeBtn = document.getElementById('mob-close');
      const mob = document.getElementById('mob');
      openBtn?.addEventListener('click', () => { mob?.classList.add('open'); document.body.style.overflow = 'hidden'; });
      closeBtn?.addEventListener('click', () => { mob?.classList.remove('open'); document.body.style.overflow = ''; });
      mob?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
        mob.classList.remove('open'); document.body.style.overflow = '';
      }));

      // ═══════════════════════════════════════════════
      // Form feedback
      // ═══════════════════════════════════════════════
      document.querySelectorAll('form[data-contact]').forEach((form) => {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const btn = form.querySelector('button[type="submit"]');
          if (!btn) return;
          btn.querySelector('span').textContent = 'Consulta enviada · gracias';
          btn.setAttribute('disabled', 'true');
          btn.style.background = '#2f5d38';
        });
      });

      // ═══════════════════════════════════════════════
      // Índice de prácticas — contador activo al hover
      // ═══════════════════════════════════════════════
      const indexItems = document.querySelectorAll('[data-index-item]');
      const indexCount = document.querySelector('[data-index-count]');
      indexItems.forEach((it, i) => {
        it.addEventListener('mouseenter', () => {
          if (indexCount) indexCount.textContent = String(i + 1).padStart(2, '0');
        });
      });
    </script>
  </body>
</html>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import { accountingRadar } from '@lib/news';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return accountingRadar.items.map((item) => ({
    params: { slug: item.slug },
    props:  { item },
  }));
};

const { item } = Astro.props as any;
const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<BaseLayout
  practice="accounting"
  title={`${item.title} — Novedades PLB Contable`}
  description={item.desc}>

  <article class="pt-32 pb-28 md:pt-40 md:pb-32 reveal">
    <div class="shell max-w-3xl mx-auto">
      <a href={withBase('/novedades-contable')} class="inline-flex items-center gap-2 font-mono text-tick uppercase tracking-tick mb-10 transition" style="color: var(--brand-500);">
        ← Todas las novedades
      </a>

      <div class="flex flex-wrap gap-2 mb-6 text-xs font-mono uppercase tracking-tick" style="color: var(--fg-subtle);">
        <span style="color: var(--brand-500);">{item.date}</span>
        <span style="opacity: 0.4">·</span>
        <span>{item.source}</span>
      </div>

      <h1 class="font-sans font-bold leading-[1.05] mb-8" style="color: var(--fg); font-size: clamp(2rem, 4.5vw, 3.5rem);">
        {item.title}
      </h1>

      <p class="text-[1.15rem] md:text-[1.3rem] leading-relaxed mb-10" style="color: var(--fg-muted);">
        {item.desc}
      </p>

      <div class="flex flex-wrap gap-2 mb-12">
        {item.categories.map((c: string) => (
          <span class="px-3 py-1.5 text-xs font-mono uppercase tracking-tick border" style="border-color: var(--border); color: var(--fg-muted);">
            {c.replace('_', ' ')}
          </span>
        ))}
      </div>

      <div class="pt-10 border-t" style="border-color: var(--border);">
        <p class="mb-6 text-sm" style="color: var(--fg-subtle);">
          Este radar se nutre del Boletín Oficial. Para el texto completo de la norma,
          acceda a la fuente oficial:
        </p>
        <a href={item.url} target="_blank" rel="noopener" class="btn-editorial">
          <span>Leer en {item.source.split('·')[0].trim()}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17 17 7M7 7h10v10"/></svg>
        </a>
      </div>

      <aside class="mt-16 p-6 border text-sm leading-relaxed" style="border-color: var(--border); color: var(--fg-muted);">
        <strong style="color: var(--fg);">Importante.</strong>
        Este resumen tiene fines informativos y no reemplaza el asesoramiento profesional.
        Para un análisis sobre cómo esta norma afecta a su empresa,
        <a href={withBase('/contable#contacto')} class="ink-link">contáctenos</a>.
      </aside>
    </div>
  </article>
</BaseLayout>

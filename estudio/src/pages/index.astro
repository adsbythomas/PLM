---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Counters from '@components/Counters.astro';
import Manifesto from '@components/Manifesto.astro';
import Practice from '@components/Practice.astro';
import Marquee from '@components/Marquee.astro';
import Approach from '@components/Approach.astro';
import Team from '@components/Team.astro';
import Timeline from '@components/Timeline.astro';
import CrossLink from '@components/CrossLink.astro';
import Contact from '@components/Contact.astro';
import { legal } from '@lib/legal';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<BaseLayout
  practice="legal"
  title="PLB Abogados — Derecho empresarial · Buenos Aires · 20 años"
  description="Estudio integral de abogados y contadores en Buenos Aires. Tributario, aduanero, societario, laboral, aerocomercial y penal económico. Corresponsalías en EE.UU. y Uruguay.">

  <Hero
    practice="legal"
    kicker={legal.hero.kicker}
    words={legal.hero.words}
    italicWord={legal.hero.italicWord}
    lead={legal.hero.lead}
    ctaPrimary={legal.hero.ctaPrimary}
    altLabel="→ Ir al área contable"
    altHref={withBase('/contable')}
    index={legal.eyebrow}
  />

  <Counters items={legal.counters} />

  <Manifesto
    label={legal.manifesto.label}
    headline={legal.manifesto.headline}
    intro={legal.manifesto.intro}
    movimientos={legal.manifesto.movimientos}
  />

  <Practice
    label={legal.practice.label}
    title={legal.practice.title}
    sub={legal.practice.sub}
    items={legal.practice.items}
  />

  <Marquee items={legal.marquee} />

  <Approach
    label={legal.approach.label}
    title={legal.approach.title}
    steps={legal.approach.steps}
  />

  <Team
    label={legal.team.label}
    title={legal.team.title}
    sub={legal.team.sub}
    members={legal.team.members}
    ctaText={legal.team.ctaText}
  />

  <Timeline
    label={legal.timeline.label}
    title={legal.timeline.title}
    items={legal.timeline.items}
  />

  <CrossLink practice="legal" />

  <Contact
    label={legal.contact.label}
    title={legal.contact.title}
    titleAccent={legal.contact.titleAccent}
    desc={legal.contact.desc}
    formAreas={legal.contact.formAreas}
    formAreaLabel="Área de consulta"
  />
</BaseLayout>

---
export interface Item { year: string; title: string; desc: string; }
export interface Props { label: string; title: string; items: Item[]; }
const { label, title, items } = Astro.props;
---
<section id="historia" class="relative py-32 md:py-chapter bg-paperDark/60 border-y border-ink-200 overflow-hidden reveal">
  <div class="shell">
    <div class="section-kicker"><span>{label}</span></div>
    <h2 class="font-serif font-semibold text-cover text-ink-900 mb-8 max-w-[900px] leading-[1.05]">
      <span class="under-ruler">{title}</span>
    </h2>
    <p class="reader text-ink-600 text-[1.1rem] leading-relaxed mb-8">
      Dos décadas acompañando a empresas. Deslizá para recorrer los hitos del estudio.
    </p>
  </div>

  <!-- Timeline horizontal con scroll snap -->
  <div class="shell">
    <div class="timeline-scroll" data-timeline>
      {items.map((it) => (
        <article class="timeline-card">
          <div class="pt-12 pr-2">
            <div class="font-mono text-tick uppercase tracking-tick mb-3" style="color: var(--brand-700)">Anno {it.year}</div>
            <div class="font-serif font-semibold text-[2.2rem] md:text-[2.6rem] leading-[1.05] text-ink-900 mb-4">
              <span class="font-mono text-sm align-top mr-2" style="color: var(--brand-700)">·</span>
              {it.title}
            </div>
            <p class="text-ink-600 leading-relaxed text-[0.98rem]">{it.desc}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-6 flex items-center justify-between text-tick uppercase tracking-tick font-mono text-ink-400">
      <span>← {items[0].year}</span>
      <span>→ {items[items.length - 1].year}</span>
    </div>
  </div>
</section>

---
// Íconos lineales simples — estilo editorial, stroke = currentColor.
export interface Props { name: string; class?: string; }
const { name, class: cls = 'w-7 h-7' } = Astro.props;
---
{name === 'tax' && (
  <svg class={cls} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="5" y="4" width="22" height="24" rx="1.5"/>
    <path d="M10 10h12M10 15h12M10 20h9"/>
    <path d="M22 25l3-3"/>
  </svg>
)}
{name === 'customs' && (
  <svg class={cls} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M16 4 4 10v10l12 6 12-6V10z"/>
    <path d="M16 4v22M4 10l12 6 12-6"/>
  </svg>
)}
{name === 'labor' && (
  <svg class={cls} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="16" cy="11" r="5"/>
    <path d="M5 27c0-5 5-9 11-9s11 4 11 9"/>

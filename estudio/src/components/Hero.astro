---
import Blueprint from './Blueprint.astro';
import Obelisco from './Obelisco.astro';
import type { Practice } from '@lib/site';
import { site } from '@lib/site';

export interface Props {
  practice: Practice;
  titleLine1: string;
  titleLine2: string;
  lead: string;
  ctaPrimary: string;
  altLabel: string;
  altHref: string;
}
const { practice, titleLine1, titleLine2, lead, ctaPrimary, altLabel, altHref } = Astro.props;
const kicker = practice === 'legal' ? 'Abogados · Buenos Aires' : 'Contadores Públicos · Buenos Aires';
---
<section class="relative overflow-hidden min-h-[90svh] flex items-center" data-hero>
  <!-- Blueprint grid sutil como fondo -->
  <div class="absolute inset-0 z-0" data-parallax data-parallax-speed="0.08">
    <Blueprint />
  </div>

  <!-- Obelisco decorativo único, a la derecha -->
  <div class="hidden lg:block absolute right-6 xl:right-16 top-1/2 -translate-y-1/2 z-0 w-[140px] xl:w-[170px] pointer-events-none opacity-[0.45]"
       style="color: var(--brand-500);" data-parallax data-parallax-speed="0.15">
    <Obelisco />
  </div>

  <!-- Contenido centrado -->
  <div class="shell relative z-10 py-32 md:py-40 w-full text-center">
    <!-- Monograma PLB -->
    <div class="mb-3">
      <h2 class="font-sans font-bold leading-none tracking-tight"
          style="font-size: clamp(3rem, 7vw, 5rem); color: var(--fg);">
        {site.abbr.a}<span style="color: var(--brand-500)">{site.abbr.b}</span>
      </h2>
    </div>

    <!-- Tagline con underline -->
    <div class="mb-14 md:mb-20 inline-flex flex-col items-center">
      <span class="font-mono text-[0.8rem] md:text-[0.9rem] uppercase tracking-[0.3em] font-medium"
            style="color: var(--brand-500)">
        {kicker}
      </span>
      <span class="mt-4 block w-12 h-px" style="background: var(--brand-500)"></span>
    </div>

    <!-- Título grande en 2 líneas, centrado -->
    <h1 class="font-sans font-bold leading-[1.08] tracking-tight max-w-[1100px] mx-auto mb-10"
        style="font-size: clamp(2.2rem, 5.5vw, 4.5rem); color: var(--fg);">
      <span class="stack-line block" data-stack-line>
        <span class="inline-block">{titleLine1}</span>
      </span>
      <span class="stack-line block" style="--delay: 160" data-stack-line>
        <span class="inline-block"><span style="color: var(--brand-500)">{titleLine2}</span></span>
      </span>
    </h1>

    <!-- Lead -->
    <p class="reveal mx-auto max-w-[820px] text-[1.05rem] md:text-[1.15rem] leading-relaxed mb-12"
       style="color: var(--fg-muted);">
      {lead}
    </p>

    <!-- CTAs -->
    <div class="reveal inline-flex flex-wrap gap-4 justify-center items-center">
      <a href="#contacto" class="btn-editorial">
        <span>{ctaPrimary}</span>
      </a>
      <a href="#practica" class="btn-outline">
        <span>Ver áreas de práctica</span>
      </a>
    </div>

    <!-- Link secundario a la otra área -->
    <div class="reveal mt-10">
      <a href={altHref} class="font-mono text-tick uppercase tracking-tick transition inline-flex items-center gap-2"
         style="color: var(--fg-subtle);">
        {altLabel}
      </a>
    </div>
  </div>
</section>

<style>
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
    background: transparent;
    border: 1px solid var(--border);
    transition: all .4s cubic-bezier(0.2, 0.6, 0.2, 1);
  }
  .btn-outline:hover {
    border-color: var(--brand-500);
    color: var(--brand-400);
  }
</style>

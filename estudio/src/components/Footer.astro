---
import { site } from '@lib/site';
import Obelisco from './Obelisco.astro';
import type { Practice } from '@lib/site';

export interface Props { practice: Practice }
const { practice } = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
const year = new Date().getFullYear();
---
<footer class="relative border-t overflow-hidden" style="border-color: var(--border)">
  <!-- Obelisco discreto — marca de lugar -->
  <div class="absolute right-6 md:right-14 top-14 w-[60px] md:w-[80px] opacity-25 pointer-events-none hidden md:block" style="color: var(--brand-500)">
    <Obelisco />
  </div>

  <div class="shell relative z-10 pt-24 pb-14">
    <!-- Cierre -->
    <div class="max-w-4xl mb-16">
      <div class="font-mono text-tick uppercase tracking-tick mb-5" style="color: var(--brand-600)">El estudio</div>
      <p class="font-sans font-bold text-cover leading-[1.1]" style="color: var(--fg)">
        Estudio integral de abogados<br/>
        y contadores públicos<br/>
        <span style="color: var(--brand-600)">en Buenos Aires.</span>
      </p>
    </div>

    <div class="grid md:grid-cols-4 gap-10 pt-14 border-t" style="border-color: var(--border)">
      <div>
        <div class="font-sans text-2xl font-semibold mb-3" style="color: var(--fg)">
          {site.abbr.a}<span style="color: var(--brand-600)">{site.abbr.b}</span> & Asocs.
        </div>
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--fg-muted)">
          Pantarotto · Lértora · Bardagí<br/>
          Abogados & Contadores Públicos
        </p>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick mb-4" style="color: var(--fg-subtle)">Navegación</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={withBase('/')} class="transition" style="color: var(--fg-muted)">Área legal</a></li>
          <li><a href={withBase('/contable')} class="transition" style="color: var(--fg-muted)">Área contable</a></li>
          <li><a href="#equipo" class="transition" style="color: var(--fg-muted)">Equipo</a></li>
          <li><a href="#historia" class="transition" style="color: var(--fg-muted)">Trayectoria</a></li>
          <li><a href="#contacto" class="transition" style="color: var(--fg-muted)">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick mb-4" style="color: var(--fg-subtle)">Estudio</h4>
        <address class="not-italic text-sm leading-relaxed" style="color: var(--fg-muted)">
          {site.address.line1}<br/>
          {site.address.line2}<br/>
          <span style="color: var(--fg-subtle)">{site.address.postalCode} · Buenos Aires</span>
        </address>
        <p class="mt-4 text-sm" style="color: var(--fg-subtle)">{site.hours}</p>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick mb-4" style="color: var(--fg-subtle)">Corresponsalías</h4>
        <ul class="space-y-2 text-sm" style="color: var(--fg-muted)">
          <li>Buenos Aires, AR</li>
          <li>New York · Miami, US</li>
          <li>Montevideo, UY</li>
        </ul>
        <a href={site.linkedin} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 mt-5 text-tick uppercase tracking-tick font-mono transition"
           style="color: var(--fg-muted)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 11.02 5.001 2.5 2.5 0 01-.02-5.001zM3 9h4v12H3zM14.5 9c-2.43 0-3.5 1.5-3.5 3V21h-4V9h4v1.7c.7-.9 2-1.7 3.5-1.7 3 0 4.5 2 4.5 5.2V21h-4v-6.5c0-1.5-.5-2.5-2-2.5z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs font-mono uppercase tracking-tick"
         style="border-color: var(--border); color: var(--fg-subtle)">
      <span>© {year} {site.firmName}</span>
      <div class="flex items-center gap-5">
        <a href="#" class="transition" style="color: var(--fg-subtle)">Privacidad</a>
        <span style="color: var(--fg-subtle); opacity: 0.4">·</span>
        <a href="#" class="transition" style="color: var(--fg-subtle)">Términos</a>
        <span style="color: var(--fg-subtle); opacity: 0.4">·</span>
        <span>Buenos Aires · {year}</span>
      </div>
    </div>
  </div>
</footer>

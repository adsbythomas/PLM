---
import { site } from '@lib/site';
import Skyline from './Skyline.astro';
import type { Practice } from '@lib/site';

export interface Props { practice: Practice }
const { practice } = Astro.props;
const isLegal = practice === 'legal';

const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
const year = new Date().getFullYear();
---
<footer class="relative bg-ink-900 text-paper overflow-hidden">
  <!-- Skyline inferior espejado -->
  <div class="absolute inset-x-0 bottom-0 h-[60%] opacity-40 pointer-events-none" style="transform: scaleY(-1); transform-origin: center bottom;">
    <Skyline />
  </div>

  <div class="shell relative z-10 pt-24 pb-14">
    <!-- Lema monumental -->
    <div class="max-w-4xl mb-20">
      <div class="font-mono text-tick uppercase tracking-tick mb-5" style="color: var(--brand-300)">Coda</div>
      <p class="font-serif font-semibold text-cover leading-[1.05]" style="color: var(--brand-50)">
        Derecho y número.<br/>
        <em style="color: var(--brand-300)">Veinte años</em> de oficio —<br/>
        trabajando al costado del papel.
      </p>
    </div>

    <!-- Grid de datos -->
    <div class="grid md:grid-cols-4 gap-10 pt-14 border-t border-paper/15">
      <div>
        <div class="font-serif text-2xl font-semibold mb-3">
          {site.abbr.a}<span style="color: var(--brand-300)">{site.abbr.b}</span> & Asocs.
        </div>
        <p class="text-paper/60 text-sm leading-relaxed max-w-xs">
          Pantarotto · Lértora · Bardagí<br/>
          Abogados & Contadores Públicos
        </p>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick text-paper/40 mb-4">Navegación</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={withBase('/')} class="text-paper/80 hover:text-paper transition">Área legal</a></li>
          <li><a href={withBase('/contable')} class="text-paper/80 hover:text-paper transition">Área contable</a></li>
          <li><a href="#equipo" class="text-paper/80 hover:text-paper transition">Equipo</a></li>
          <li><a href="#historia" class="text-paper/80 hover:text-paper transition">Trayectoria</a></li>
          <li><a href="#contacto" class="text-paper/80 hover:text-paper transition">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick text-paper/40 mb-4">Estudio</h4>
        <address class="not-italic text-sm text-paper/80 leading-relaxed">
          {site.address.line1}<br/>
          {site.address.line2}<br/>
          <span class="text-paper/50">{site.address.postalCode} · Buenos Aires</span>
        </address>
        <p class="mt-4 text-sm text-paper/60">{site.hours}</p>
      </div>

      <div>
        <h4 class="font-mono text-tick uppercase tracking-tick text-paper/40 mb-4">Corresponsalías</h4>
        <ul class="space-y-2 text-sm text-paper/80">
          <li>Buenos Aires, AR</li>
          <li>New York · Miami, US</li>
          <li>Montevideo, UY</li>
        </ul>
        <a href={site.linkedin} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 mt-5 text-tick uppercase tracking-tick font-mono text-paper/80 hover:text-paper">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 11.02 5.001 2.5 2.5 0 01-.02-5.001zM3 9h4v12H3zM14.5 9c-2.43 0-3.5 1.5-3.5 3V21h-4V9h4v1.7c.7-.9 2-1.7 3.5-1.7 3 0 4.5 2 4.5 5.2V21h-4v-6.5c0-1.5-.5-2.5-2-2.5z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-paper/15 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-paper/40 font-mono uppercase tracking-tick">
      <span>© {year} {site.firmName}</span>
      <div class="flex items-center gap-5">
        <a href="#" class="hover:text-paper/80 transition">Privacidad</a>
        <span class="text-paper/20">·</span>
        <a href="#" class="hover:text-paper/80 transition">Términos</a>
        <span class="text-paper/20">·</span>
        <span>Sitio: Buenos Aires, MMXXVI</span>
      </div>
    </div>
  </div>
</footer>

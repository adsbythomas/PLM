---
export interface Step { num: string; title: string; body: string; }
export interface Props { label: string; title: string; steps: Step[]; }
const { label, title, steps } = Astro.props;
---
<section id="metodo" class="relative py-32 md:py-chapter bg-ink-900 text-paper overflow-hidden reveal">
  <!-- Marca de agua textura -->
  <div class="absolute inset-0 opacity-[0.06] pointer-events-none">
    <svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 100">
      <defs>
        <pattern id="hatch" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100" height="100" fill="url(#hatch)"/>
    </svg>
  </div>

  <div class="shell relative">
    <div class="section-kicker" style="color: var(--brand-300)"><span>{label}</span></div>

    <h2 class="font-serif font-semibold text-cover text-paper leading-[1.05] mb-16 max-w-[900px]">
      <span class="under-ruler">{title}</span>
    </h2>

    <ol class="grid md:grid-cols-3 gap-10 md:gap-16">
      {steps.map((s, i) => (
        <li class="approach-step" data-step={s.num} style={`transition-delay: ${i * 120}ms`}>
          <h3 class="font-serif italic text-[1.9rem] md:text-[2.3rem] leading-tight mb-4 text-paper">
            {s.title}
          </h3>
          <p class="text-paper/70 leading-relaxed text-[0.98rem]">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

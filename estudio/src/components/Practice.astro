---
export interface Area { key: string; name: string; desc: string; }
export interface Props {
  label: string;
  title: string;
  sub: string;
  items: Area[];
}
const { label, title, sub, items } = Astro.props;

// Íconos por área — cada uno es una figura inequívoca.
// SVG inline (viewBox 80x80), stroke = currentColor.
const icons: Record<string, string> = {
  // ⚖️ Balanza — tributario
  tributario:
    '<path d="M40 14 V70"/>' +
    '<path d="M18 24 H62"/>' +
    '<path d="M40 24 L28 48 A12 12 0 0 0 52 48 Z" stroke-linejoin="round"/>' +
    '<path d="M14 20 L40 24 M40 24 L66 20"/>' +
    '<path d="M30 70 H50"/>',

  // 📦 Container — aduanero
  aduanero:
    '<rect x="10" y="24" width="60" height="42" rx="1"/>' +
    '<path d="M20 24 V66 M30 24 V66 M40 24 V66 M50 24 V66 M60 24 V66"/>' +
    '<path d="M10 32 H70 M10 58 H70"/>',

  // 👥 Dos personas — laboral
  laboral:
    '<circle cx="28" cy="28" r="8"/>' +
    '<path d="M14 60 Q28 46 42 60"/>' +
    '<circle cx="54" cy="30" r="7"/>' +
    '<path d="M40 60 Q54 48 68 60"/>',

  // 🏛️ Edificio clásico con columnas — societario
  societario:
    '<path d="M10 28 L40 12 L70 28"/>' +
    '<path d="M10 28 H70"/>' +
    '<path d="M18 32 V60 M30 32 V60 M42 32 V60 M54 32 V60 M66 32 V60"/>' +
    '<path d="M6 64 H74"/>' +
    '<path d="M10 68 H70"/>',

  // ✈️ Avión — aerocomercial
  aerocomercial:
    '<path d="M14 46 L68 22 Q72 22 72 26 L48 52 L54 70 L49 73 L38 60 L24 68 L18 66 L26 52 L14 52 L12 50 L10 46 Z" stroke-linejoin="round"/>',

  // 🔨 Gavel — penal económico
  penal:
    '<rect x="20" y="14" width="32" height="12" rx="1" transform="rotate(-15 36 20)"/>' +
    '<rect x="34" y="30" width="6" height="26" transform="rotate(-15 37 43)"/>' +
    '<path d="M8 68 H72"/>' +
    '<rect x="14" y="60" width="46" height="8" rx="1"/>',

  // ⚖️ Fallback
  default: '<circle cx="40" cy="40" r="24"/><path d="M26 40 L36 50 L54 30"/>',

  // ───── CONTABLES ─────

  // 💵 Recibo / documento con signo $
  impuestos:
    '<path d="M18 8 L56 8 L56 72 L50 68 L44 72 L38 68 L32 72 L26 68 L18 72 Z" stroke-linejoin="round"/>' +
    '<path d="M26 22 H48 M26 30 H48 M26 38 H40"/>' +
    '<path d="M37 46 V60"/>' +
    '<path d="M30 49 Q37 46 44 49 Q48 52 44 55 Q37 58 30 55 Q27 58 30 61 Q37 64 44 61"/>',

  // 📊 Gráfico de barras — estados contables
  estados:
    '<path d="M10 70 V14"/>' +
    '<path d="M10 70 H72"/>' +
    '<rect x="18" y="52" width="8" height="18"/>' +
    '<rect x="32" y="40" width="8" height="30"/>' +
    '<rect x="46" y="28" width="8" height="42"/>' +
    '<rect x="60" y="46" width="8" height="24"/>',

  // 🔍 Lupa — auditoría
  auditoria:
    '<circle cx="32" cy="32" r="20"/>' +
    '<path d="M46 46 L68 68"/>' +
    '<path d="M24 28 H40 M24 34 H38 M24 40 H34"/>',

  // 🎯 Target — planificación impositiva
  planificacion:
    '<circle cx="40" cy="40" r="26"/>' +
    '<circle cx="40" cy="40" r="17"/>' +
    '<circle cx="40" cy="40" r="8"/>' +
    '<circle cx="40" cy="40" r="2.5" fill="currentColor"/>' +
    '<path d="M10 10 L35 35"/>' +
    '<path d="M28 10 L35 10 L35 17"/>',

  // 💰 Billetera / sueldos
  sueldos:
    '<path d="M12 22 H60 L60 30"/>' +
    '<path d="M12 22 V65 A2 2 0 0 0 14 67 H66 A2 2 0 0 0 68 65 V30 A2 2 0 0 0 66 28 H12"/>' +
    '<circle cx="56" cy="46" r="2.5" fill="currentColor"/>' +
    '<path d="M56 36 L66 36 M56 56 L66 56" stroke-dasharray="2 3"/>',

  // 🌐 Globo — contabilidad internacional
  internacional:
    '<circle cx="40" cy="40" r="26"/>' +
    '<path d="M14 40 H66"/>' +
    '<ellipse cx="40" cy="40" rx="26" ry="13"/>' +
    '<path d="M40 14 Q52 28 52 40 Q52 52 40 66 M40 14 Q28 28 28 40 Q28 52 40 66"/>',
};
---
<section id="practica" class="relative py-28 md:py-32 reveal">
  <div class="shell grid md:grid-cols-[1fr_1.8fr] gap-12 md:gap-20">
    <!-- Columna sticky con título + ícono dinámico que cambia al hover -->
    <aside class="md:sticky md:top-28 self-start">
      <div class="section-kicker"><span>{label}</span></div>
      <h2 class="font-sans font-bold text-cover text-ink-900 leading-[1.05]">
        <span class="stack-line inline-block" data-stack-line><span>{title}</span></span>
      </h2>
      <p class="mt-6 text-ink-600 max-w-md leading-relaxed">{sub}</p>

      <!-- Ícono grande que cambia al hacer hover en cada área -->
      <div class="mt-10 hidden md:block">
        <div class="relative w-[280px] aspect-square border border-ink-200 bg-paperDark/30">
          {items.map((a, i) => (
            <svg
              data-area-icon={a.key}
              viewBox="0 0 80 80"
              class="absolute inset-0 w-full h-full p-12 opacity-0 transition-opacity duration-500"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`color: var(--brand-700); ${i === 0 ? 'opacity:1;' : ''}`}
              set:html={icons[a.key] || icons.default}
            />
          ))}
          <!-- Label del área activa -->
          <div class="absolute bottom-4 left-4 font-mono text-tick uppercase tracking-tick text-ink-400" data-area-label>
            {items[0].name}
          </div>
          <!-- Contador -->
          <div class="absolute top-4 right-4 font-mono text-tick uppercase tracking-tick text-ink-400">
            <span data-index-count>01</span> / {String(items.length).padStart(2, '0')}
          </div>
        </div>
      </div>
    </aside>

    <!-- Lista de áreas -->
    <div class="space-y-0" data-index>
      {items.map((a, i) => (
        <a href="#contacto"
           class="block index-row group"
           data-index-item
           data-area-key={a.key}
           data-area-name={a.name}>
          <span class="index-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <span class="index-name">{a.name}</span>
            <p class="index-desc">{a.desc}</p>
          </div>
          <span class="index-arrow">Consultar →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Sincroniza el ícono + label de la columna sticky con el área sobre la que está el mouse.
  const items = document.querySelectorAll('[data-index-item]');
  const icons = document.querySelectorAll('[data-area-icon]');
  const count = document.querySelector('[data-index-count]');
  const label = document.querySelector('[data-area-label]');

  items.forEach((it, i) => {
    it.addEventListener('mouseenter', () => {
      const key = it.getAttribute('data-area-key');
      const name = it.getAttribute('data-area-name');
      icons.forEach((icon) => {
        const match = icon.getAttribute('data-area-icon') === key;
        (icon as HTMLElement).style.opacity = match ? '1' : '0';
      });
      if (count) count.textContent = String(i + 1).padStart(2, '0');
      if (label && name) label.textContent = name;
    });
  });
</script>

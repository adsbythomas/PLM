---
export interface Sector { name: string; desc: string }
export interface Props {
  label: string;
  title: string;
  sub: string;
  items: Sector[];
}
const { label, title, sub, items } = Astro.props;
---
<section id="sectores" class="shell py-24 md:py-32 reveal">
  <header class="max-w-3xl mb-14">
    <div class="eyebrow mb-3">{label}</div>
    <h2 class="section-title">{title}</h2>
    <p class="mt-4 text-ink-600 leading-relaxed">{sub}</p>
  </header>

  <ul class="grid gap-x-10 gap-y-0 md:grid-cols-2 lg:grid-cols-3 divide-y md:divide-y-0 md:[&>li]:border-b md:[&>li]:border-ink-200">
    {items.map((s, i) => (
      <li class="py-6 flex items-start gap-5">
        <span class="font-serif text-sm text-ink-400 pt-1">/{String(i + 1).padStart(2, '0')}</span>
        <div>
          <h3 class="font-serif font-semibold text-lg text-ink-900">{s.name}</h3>
          <p class="mt-1.5 text-sm text-ink-600 leading-relaxed">{s.desc}</p>
        </div>
      </li>
    ))}
  </ul>
</section>

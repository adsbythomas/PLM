---
export interface Member { initials: string; name: string; role: string; spec: string; bio?: string; }
export interface Props {
  label: string;
  title: string;
  sub: string;
  members: Member[];
  ctaText: string;
}
const { label, title, sub, members, ctaText } = Astro.props;
---
<section id="equipo" class="relative py-32 md:py-chapter reveal">
  <div class="shell">
    <div class="section-kicker"><span>{label}</span></div>
    <h2 class="font-serif font-semibold text-cover text-ink-900 mb-6 max-w-[800px] leading-[1.05]">
      <span class="under-ruler">{title}</span>
    </h2>
    <p class="reader text-ink-600 text-[1.1rem] leading-relaxed mb-20">{sub}</p>
  </div>

  <div class="shell">
    {members.map((m, i) => (
      <article class="team-row" data-team-row>
        <div class="grid md:grid-cols-[auto_1fr] gap-10 md:gap-20 items-center">
          <div class="team-meta font-mono text-tick uppercase tracking-tick" style="color: var(--brand-700)">
            <div>0{i + 1} · {m.role}</div>
            <div class="text-ink-400 mt-2">{m.spec}</div>
          </div>
          <div class="team-name leading-none text-ink-900">
            {m.name}
          </div>
        </div>
        {m.bio && (
          <p class="team-meta text-ink-600 leading-relaxed max-w-reader mt-8 md:ml-[260px] text-[0.98rem]">{m.bio}</p>
        )}
      </article>
    ))}

    <div class="reveal grid md:grid-cols-[auto_1fr] gap-10 md:gap-20 items-center py-14 border-y border-ink-200">
      <div class="font-mono text-tick uppercase tracking-tick text-ink-400">+ Equipo completo</div>
      <div class="flex items-center gap-6 flex-wrap">
        <p class="font-serif italic text-ink-700 text-[1.2rem] md:text-[1.4rem] leading-snug max-w-xl">
          {ctaText}
        </p>
        <a href="#contacto" class="ink-link font-mono text-tick uppercase tracking-tick">Contactar</a>
      </div>
    </div>
  </div>
</section>
